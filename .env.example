# The site runs with NO environment variables — every value below is optional.
# Copy this file to `.env.local` only if you want to override the defaults.

# Blog + insights CMS (Sanity). Defaults to Carve's public, read-only project,
# so the blog works out of the box with nothing set here. Override these to
# point the blog/insights pages at your own Sanity project + dataset.
# NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# NEXT_PUBLIC_SANITY_DATASET=production
